<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/documentsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFA"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dokumente"
            android:textColor="#004D57"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/backToDashboardButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="← Zurück zur Übersicht"
            android:textColor="#00A99D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Checkliste deiner benötigten BAföG-Unterlagen."
            android:textColor="#263238"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Alle"
                android:textColor="#004D57"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Hochgeladen"
                android:textColor="#607D8B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Fehlt"
                android:textColor="#607D8B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="In Prüfung"
                android:textColor="#607D8B"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:background="#00A99D" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="📄 Immatrikulationsbescheinigung&#10;Hochgeladen am 12.05.2025&#10;&#10;Status: hochgeladen ✓"
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="📄 Mietvertrag&#10;Hochgeladen am 10.05.2025&#10;&#10;Status: hochgeladen ✓"
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFF3F3"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="📄 Einkommensnachweis Eltern&#10;Noch nicht hochgeladen&#10;&#10;Status: fehlt !"
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFF8E1"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="📄 Krankenversicherungsnachweis&#10;Hochgeladen am 11.05.2025&#10;&#10;Status: in Prüfung ⏳"
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/uploadDocumentCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:gravity="center"
            android:padding="24dp"
            android:text="☁ Dokument hochladen&#10;PDF, JPG oder PNG"
            android:textColor="#004D57"
            android:textSize="17sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
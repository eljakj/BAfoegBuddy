<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFA"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Übersicht"
            android:textColor="#004D57"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Hallo Jad 👋\nHier ist der aktuelle Stand deines BAföG-Antrags."
            android:textColor="#263238"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/applicationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mein Antrag"
                android:textColor="#263238"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Antrag zu 70% vollständig"
                android:textColor="#263238"
                android:textSize="18sp" />

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="18dp"
                android:max="100"
                android:progress="70"
                android:progressTint="#00A99D"
                android:progressBackgroundTint="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="70 %"
                android:textColor="#00A99D"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/documentsCard"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFF8E1"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Fehlende Unterlagen\n3 Dokumente fehlen noch"
            android:textColor="#263238"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/deadlinesCard"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#E3F2FD"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Fristen\nNächste Frist in 18 Tagen\n15.06.2026"
            android:textColor="#263238"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/followUpsCard"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#F3E5F5"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Nachforderungen\n1 offene Nachforderung"
            android:textColor="#263238"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#E8F5E9"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Letzte Sicherung\nHeute, 10:24 Uhr ✓"
            android:textColor="#263238"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/followUpsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFA"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nachforderungen"
            android:textColor="#004D57"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/backToDashboardButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="← Zurück zur Übersicht"
            android:textColor="#00A99D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Offene Anforderungen vom BAföG-Amt im Überblick."
            android:textColor="#263238"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="#FFF3F3"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Nachforderung vom BAföG-Amt&#10;Erhalten am: 12.05.2025"
            android:textColor="#B00020"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Bitte reiche folgende Unterlagen nach:&#10;&#10;- Einkommensnachweis Eltern&#10;- Aktuelle Mietbescheinigung"
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFEBEE"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Frist zur Einreichung&#10;30.05.2025&#10;in 18 Tagen"
            android:textColor="#B00020"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Status: Offen&#10;&#10;Notiz: Elternnachweis ist in Bearbeitung. Mietbescheinigung beim Vermieter angefragt."
            android:textColor="#263238"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:padding="20dp"
            android:text="Erinnerung\nErinnerung aktiv\n3 Tage vor Frist"
            android:textColor="#263238"
            android:textSize="17sp" />

        <Button
            android:id="@+id/markDoneButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="#00A99D"
            android:text="Erledigt markieren"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/addDocumentButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="#FFFFFF"
            android:text="Dokument hinzufügen"
            android:textColor="#00A99D" />

    </LinearLayout>
</ScrollView>